# ===========================================
# AI Try-On Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# RevenueCat (Optional - for in-app purchases)
# Get from: https://app.revenuecat.com/
VITE_REVENUECAT_API_KEY=""

# Feature Flags (Optional)
VITE_ENABLE_PRO_FEATURES="false"
VITE_ENABLE_GEMS="false"

# ===========================================
# Edge Function Configuration (Supabase Secrets)
# ===========================================
# Set these as Supabase secrets using:
# supabase secrets set ALLOWED_ORIGINS="https://your-domain.com"

# CORS Allowed Origins (comma-separated)
# Example: "https://myapp.com,https://staging.myapp.com,https://myapp.netlify.app"
# ALLOWED_ORIGINS="https://your-production-domain.com"
